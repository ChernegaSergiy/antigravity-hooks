{
  "walle-sounds": {
    "PreToolUse": [
      {
        "matcher": "search_web",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${ANTIGRAVITY_PLUGIN_ROOT:-$HOME/.gemini/config/plugins/walle-sounds}/play_sound.sh\" PreToolUseSearch",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "run_command",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${ANTIGRAVITY_PLUGIN_ROOT:-$HOME/.gemini/config/plugins/walle-sounds}/play_sound.sh\" PreToolUseTerminal",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "write_to_file|replace_file_content|multi_replace_file_content",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${ANTIGRAVITY_PLUGIN_ROOT:-$HOME/.gemini/config/plugins/walle-sounds}/play_sound.sh\" PreToolUseEdit",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "ask_question",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${ANTIGRAVITY_PLUGIN_ROOT:-$HOME/.gemini/config/plugins/walle-sounds}/play_sound.sh\" PreToolUseAsk",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "view_file|list_dir|grep_search",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${ANTIGRAVITY_PLUGIN_ROOT:-$HOME/.gemini/config/plugins/walle-sounds}/play_sound.sh\" PreToolUseScan",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "ask_permission",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${ANTIGRAVITY_PLUGIN_ROOT:-$HOME/.gemini/config/plugins/walle-sounds}/play_sound.sh\" PreToolUsePermission",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "invoke_subagent|define_subagent|send_message|manage_subagents|schedule|manage_task|read_url|read_url_content",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${ANTIGRAVITY_PLUGIN_ROOT:-$HOME/.gemini/config/plugins/walle-sounds}/play_sound.sh\" PreToolUse",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "bash \"${ANTIGRAVITY_PLUGIN_ROOT:-$HOME/.gemini/config/plugins/walle-sounds}/play_sound.sh\" PostToolUse",
        "timeout": 5
      }
    ],
    "PreInvocation": [
      {
        "type": "command",
        "command": "bash \"${ANTIGRAVITY_PLUGIN_ROOT:-$HOME/.gemini/config/plugins/walle-sounds}/play_sound.sh\" PreInvocation",
        "timeout": 5
      }
    ],
    "PostInvocation": [
      {
        "type": "command",
        "command": "bash \"${ANTIGRAVITY_PLUGIN_ROOT:-$HOME/.gemini/config/plugins/walle-sounds}/play_sound.sh\" PostInvocation",
        "timeout": 5
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "bash \"${ANTIGRAVITY_PLUGIN_ROOT:-$HOME/.gemini/config/plugins/walle-sounds}/play_sound.sh\" Stop",
        "timeout": 5
      }
    ]
  }
}
